#!/usr/bin/env bash
set -euo pipefail

MODE="${1:---local-only}"
MODE_ARG="${2:-}"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

COMPETITION_SLUG="${COMPETITION_SLUG:-__COMPETITION_SLUG__}"
COMPETITION_URL="${COMPETITION_URL:-__COMPETITION_URL__}"
COMPETITION_MODE="${COMPETITION_MODE:-hybrid}"
KAGGLE_SCORE_BACKEND="${KAGGLE_SCORE_BACKEND:-kaggle_native}"
KERNEL_OWNER="${KERNEL_OWNER:-__KERNEL_OWNER__}"
KERNEL_SLUG="${KERNEL_SLUG:-__KERNEL_SLUG__}"
KERNEL_REF="${KERNEL_OWNER}/${KERNEL_SLUG}"
LEADERBOARD_TEAM_NAME="${LEADERBOARD_TEAM_NAME:-}"

NOTEBOOK_SRC="${NOTEBOOK_SRC:-notebook.py}"
NOTEBOOK_IPYNB="${NOTEBOOK_IPYNB:-notebook.ipynb}"
LOCAL_RUN_CMD="${LOCAL_RUN_CMD:-python3 ${NOTEBOOK_SRC}}"
METRICS_FILE="${METRICS_FILE:-outputs/metrics.json}"
SUBMISSION_FILE="${SUBMISSION_FILE:-__SUBMISSION_ARTIFACT__}"
STATE_FILE="${STATE_FILE:-outputs/kaggle_state.json}"
KERNEL_OUTPUT_DIR="${KERNEL_OUTPUT_DIR:-outputs/kernel-output}"
PENDING_SUBMISSION_QUEUE="${PENDING_SUBMISSION_QUEUE:-outputs/pending_submission_queue.jsonl}"
CANDIDATES_DIR="${CANDIDATES_DIR:-outputs/candidates}"

PLACEHOLDER_PUBLIC_RANK="${PLACEHOLDER_PUBLIC_RANK:-999999}"
PLACEHOLDER_PUBLIC_SCORE="${PLACEHOLDER_PUBLIC_SCORE:-0}"
MAX_DAILY_SUBMISSIONS="${MAX_DAILY_SUBMISSIONS:-__SUBMISSION_CAP__}"
KAGGLE_NOTEBOOK_POLL_SECONDS="${KAGGLE_NOTEBOOK_POLL_SECONDS:-20}"
KAGGLE_SCORE_POLL_SECONDS="${KAGGLE_SCORE_POLL_SECONDS:-15}"
KAGGLE_PENDING_TIMEOUT_MINUTES="${KAGGLE_PENDING_TIMEOUT_MINUTES:-180}"
NOTEBOOK_RUNTIME_LIMIT_SECONDS="${NOTEBOOK_RUNTIME_LIMIT_SECONDS:-__NOTEBOOK_RUNTIME_LIMIT_SECONDS__}"
NOTEBOOK_RUNTIME_SAFETY_MARGIN_SECONDS="${NOTEBOOK_RUNTIME_SAFETY_MARGIN_SECONDS:-__NOTEBOOK_RUNTIME_SAFETY_MARGIN_SECONDS__}"
NOTEBOOK_RUNTIME_BUDGET_SECONDS="${NOTEBOOK_RUNTIME_BUDGET_SECONDS:-__NOTEBOOK_RUNTIME_BUDGET_SECONDS__}"
CV_DIRECTION="${CV_DIRECTION:-__CV_DIRECTION__}"

KAGGLE_NOTEBOOK_PUSH_CMD="${KAGGLE_NOTEBOOK_PUSH_CMD:-}"
KAGGLE_NOTEBOOK_IDENTITY_CMD="${KAGGLE_NOTEBOOK_IDENTITY_CMD:-}"
KAGGLE_NOTEBOOK_SCORE_CMD="${KAGGLE_NOTEBOOK_SCORE_CMD:-kaggle notebook-score}"

mkdir -p "$(dirname "$METRICS_FILE")" "$KERNEL_OUTPUT_DIR" "$CANDIDATES_DIR"
CURRENT_SUBMISSION_COUNT=""

die() {
  echo "ERROR: $*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

emit_metric() {
  local name="$1"
  local value="$2"
  echo "METRIC ${name}=${value}"
}

info() {
  echo "INFO $*"
}

normalize_competition_mode() {
  case "$COMPETITION_MODE" in
    file_upload|notebook_scored|hybrid)
      ;;
    *)
      die "Unsupported COMPETITION_MODE=${COMPETITION_MODE}. Use file_upload, notebook_scored, or hybrid."
      ;;
  esac
}

load_env_file_if_present() {
  local env_file="${KAGGLE_ENV_FILE:-.env}"
  if [[ -f "$env_file" ]]; then
    set -a
    # shellcheck disable=SC1090
    . "$env_file"
    set +a
  fi
}

load_kaggle_auth() {
  load_env_file_if_present

  if [[ -n "${KAGGLE_API_TOKEN:-}" && -z "${KAGGLE_KEY:-}" ]]; then
    export KAGGLE_KEY
    KAGGLE_KEY="${KAGGLE_API_TOKEN}"
  fi

  local config_dir="${KAGGLE_CONFIG_DIR:-$HOME/.kaggle}"
  local token_file="${KAGGLE_TOKEN_FILE:-}"
  if [[ -z "$token_file" ]]; then
    for candidate in \
      "${config_dir}/access_token" \
      "${config_dir}/access_token.txt" \
      "${ROOT_DIR}/.kaggle/access_token" \
      "${ROOT_DIR}/.kaggle/access_token.txt"
    do
      if [[ -f "$candidate" ]]; then
        token_file="$candidate"
        break
      fi
    done
  fi

  if [[ -n "$token_file" && -z "${KAGGLE_API_TOKEN:-}" ]]; then
    export KAGGLE_API_TOKEN
    KAGGLE_API_TOKEN="$(tr -d '\r\n' < "$token_file")"
  fi

  if [[ -n "${KAGGLE_API_TOKEN:-}" && -z "${KAGGLE_KEY:-}" ]]; then
    export KAGGLE_KEY
    KAGGLE_KEY="${KAGGLE_API_TOKEN}"
  fi
}

resolve_leaderboard_team_name() {
  if [[ -z "${LEADERBOARD_TEAM_NAME:-}" ]]; then
    LEADERBOARD_TEAM_NAME="${KERNEL_OWNER}"
  fi
}

detect_local_accelerator() {
  if [[ -n "${LOCAL_ACCELERATOR:-}" ]]; then
    printf '%s\n' "$LOCAL_ACCELERATOR"
    return 0
  fi

  if command -v nvidia-smi >/dev/null 2>&1; then
    printf 'cuda\n'
    return 0
  fi

  if command -v rocm-smi >/dev/null 2>&1; then
    printf 'rocm\n'
    return 0
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - <<'PY'
try:
    import torch
except Exception:
    print("cpu")
    raise SystemExit(0)

try:
    if torch.cuda.is_available():
        print("cuda")
        raise SystemExit(0)
except Exception:
    pass

try:
    mps = getattr(torch.backends, "mps", None)
    if mps is not None and mps.is_available():
        print("mps")
        raise SystemExit(0)
except Exception:
    pass

print("cpu")
PY
    return 0
  fi

  printf 'cpu\n'
}

prepare_local_accelerator() {
  export LOCAL_ACCELERATOR="${LOCAL_ACCELERATOR:-$(detect_local_accelerator)}"
  info "local_accelerator=${LOCAL_ACCELERATOR}"
}

ensure_state_file() {
  python3 - "$STATE_FILE" "$PLACEHOLDER_PUBLIC_RANK" "$PLACEHOLDER_PUBLIC_SCORE" <<'PY'
import json
import sys
from pathlib import Path

state_path = Path(sys.argv[1])
rank = float(sys.argv[2])
score = float(sys.argv[3])

if not state_path.exists():
    state_path.write_text(
        json.dumps(
            {
                "public_rank": rank,
                "public_score": score,
                "submission_count": 0,
                "last_submission_path": "",
                "last_public_metrics_timestamp": 0,
                "last_submission_id": "",
                "last_candidate_id": "",
            },
            indent=2,
        )
        + "\n"
    )
PY
}

read_state_value() {
  local key="$1"
  local default_value="$2"
  python3 - "$STATE_FILE" "$key" "$default_value" <<'PY'
import json
import sys
from pathlib import Path

state_path = Path(sys.argv[1])
key = sys.argv[2]
default_value = sys.argv[3]

if not state_path.exists():
    print(default_value)
    raise SystemExit(0)

payload = json.loads(state_path.read_text())
value = payload.get(key, default_value)
if isinstance(value, (dict, list)):
    print(json.dumps(value))
else:
    print(value)
PY
}

persist_state() {
  local public_rank="$1"
  local public_score="$2"
  local submission_count="$3"
  local submission_path="$4"
  local public_metrics_timestamp="${5:-0}"
  local submission_id="${6:-}"
  local candidate_id="${7:-}"

  python3 - "$STATE_FILE" "$public_rank" "$public_score" "$submission_count" "$submission_path" "$public_metrics_timestamp" "$submission_id" "$candidate_id" <<'PY'
import json
import sys
from pathlib import Path

state_path = Path(sys.argv[1])
payload = {
    "public_rank": float(sys.argv[2]),
    "public_score": float(sys.argv[3]),
    "submission_count": int(float(sys.argv[4])),
    "last_submission_path": sys.argv[5],
    "last_public_metrics_timestamp": int(float(sys.argv[6])) if sys.argv[6] not in ("", "0") else 0,
    "last_submission_id": sys.argv[7],
    "last_candidate_id": sys.argv[8],
}
state_path.write_text(json.dumps(payload, indent=2) + "\n")
PY
}

read_metrics_value() {
  local key="$1"
  local default_value="$2"
  python3 - "$METRICS_FILE" "$key" "$default_value" <<'PY'
import json
import sys
from pathlib import Path

metrics_path = Path(sys.argv[1])
key = sys.argv[2]
default_value = sys.argv[3]

if not metrics_path.exists():
    print(default_value)
    raise SystemExit(0)

payload = json.loads(metrics_path.read_text())
value = payload.get(key, default_value)
if isinstance(value, (dict, list)):
    print(json.dumps(value))
else:
