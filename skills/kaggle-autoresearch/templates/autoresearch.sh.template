queue_pending_candidate() {
  local candidate_id="$1"
  local submission_count="$2"
  local merge_inputs="${3:-}"
  local cv_score
  local public_rank
  local public_score
  local submission_file
  local priority
  cv_score="$(candidate_metric_value "$candidate_id" "cv_score" "$(read_metrics_value "cv_score" "0")")"
  public_rank="$(candidate_metric_value "$candidate_id" "public_rank" "$(read_state_value "public_rank" "$PLACEHOLDER_PUBLIC_RANK")")"
  public_score="$(candidate_metric_value "$candidate_id" "public_score" "$(read_state_value "public_score" "$PLACEHOLDER_PUBLIC_SCORE")")"
  submission_file="$(candidate_submission_file "$candidate_id")"
  priority="$(candidate_metric_value "$candidate_id" "pending_priority" "$cv_score")"

  python3 - "$PENDING_SUBMISSION_QUEUE" "$COMPETITION_SLUG" "$candidate_id" "$cv_score" "$public_rank" "$public_score" "$submission_count" "$submission_file" "${LOCAL_ACCELERATOR:-cpu}" "$priority" "$merge_inputs" <<'PY'
import json
import sys
import time
from pathlib import Path

queue_path = Path(sys.argv[1])
queue_path.parent.mkdir(parents=True, exist_ok=True)
payload = {
    "timestamp": int(time.time()),
    "competition_slug": sys.argv[2],
    "candidate_id": sys.argv[3],
    "cv_score": float(sys.argv[4]),
    "public_rank": float(sys.argv[5]),
    "public_score": float(sys.argv[6]),
    "submission_count": int(float(sys.argv[7])),
    "submission_file": sys.argv[8],
    "local_accelerator": sys.argv[9],
    "priority": float(sys.argv[10]),
    "merge_inputs": [item for item in sys.argv[11].split(",") if item],
    "status": "pending_submission_window",
}
with queue_path.open("a", encoding="utf-8") as handle:
    handle.write(json.dumps(payload) + "\n")
PY
}

select_best_pending_candidate() {
  python3 - "$PENDING_SUBMISSION_QUEUE" "$CV_DIRECTION" <<'PY'
import json
import sys
from pathlib import Path

queue_path = Path(sys.argv[1])
cv_direction = (sys.argv[2] or "higher").strip().lower()
if not queue_path.exists():
    print("")
    raise SystemExit(0)

entries = []
for line in queue_path.read_text().splitlines():
    if not line.strip():
        continue
    try:
        payload = json.loads(line)
    except json.JSONDecodeError:
        continue
    candidate_id = payload.get("candidate_id")
    if not candidate_id:
        continue
    entries.append(payload)

if not entries:
    print("")
    raise SystemExit(0)

latest = {}
for entry in entries:
    latest[entry["candidate_id"]] = entry

ordered = list(latest.values())
reverse = cv_direction == "higher"
ordered.sort(key=lambda item: (item.get("priority", item.get("cv_score", 0.0)), -item.get("timestamp", 0)) if reverse else (item.get("priority", item.get("cv_score", 0.0)), item.get("timestamp", 0)), reverse=reverse)
print(ordered[0]["candidate_id"])
PY
}

remove_queued_candidate() {
  local candidate_id="$1"
  python3 - "$PENDING_SUBMISSION_QUEUE" "$candidate_id" <<'PY'
import json
import sys
from pathlib import Path

queue_path = Path(sys.argv[1])
candidate_id = sys.argv[2]
if not queue_path.exists():
    raise SystemExit(0)

kept = []
for line in queue_path.read_text().splitlines():
    if not line.strip():
        continue
    try:
        payload = json.loads(line)
    except json.JSONDecodeError:
        continue
    if payload.get("candidate_id") == candidate_id:
        continue
    kept.append(json.dumps(payload))

queue_path.write_text("\n".join(kept) + ("\n" if kept else ""))
PY
}

