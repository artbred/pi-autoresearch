handle_submission_budget_pause() {
  local candidate_id="${1:-}"
  local cv_score
  local public_rank
  local public_score
  local last_submission_path
  local last_public_metrics_timestamp
  local last_submission_id

  cv_score="$(read_metrics_value "cv_score" "0")"
  public_rank="$(read_state_value "public_rank" "$PLACEHOLDER_PUBLIC_RANK")"
  public_score="$(read_state_value "public_score" "$PLACEHOLDER_PUBLIC_SCORE")"
  last_submission_path="$(read_state_value "last_submission_path" "")"
  last_public_metrics_timestamp="$(read_state_value "last_public_metrics_timestamp" "0")"
  last_submission_id="$(read_state_value "last_submission_id" "")"

  if [[ -n "$candidate_id" ]]; then
    clear_manifest_overrides
    write_candidate_manifest "$candidate_id" "quota_exhausted" "" "$cv_score" "$last_public_metrics_timestamp" "$last_submission_id"
    queue_pending_candidate "$candidate_id" "$CURRENT_SUBMISSION_COUNT"
  fi
  persist_state "$public_rank" "$public_score" "$CURRENT_SUBMISSION_COUNT" "$last_submission_path" "$last_public_metrics_timestamp" "$last_submission_id" "$candidate_id"

  info "submission_budget_reached=1"
  info "submission_window=closed"
  info "submission_count=${CURRENT_SUBMISSION_COUNT}/${MAX_DAILY_SUBMISSIONS}"
  info "continue_mode=local_only"
  info "queued_candidate=${candidate_id:-none}"
  info "queue_file=${PENDING_SUBMISSION_QUEUE}"

  emit_local_metrics "$CURRENT_SUBMISSION_COUNT"
}

submit_to_competition() {
  local submission_path="$1"
  local cv_score="$2"
  local message="autoresearch $(date +%Y-%m-%dT%H:%M:%S) cv=${cv_score}"
  kaggle competitions submit "$COMPETITION_SLUG" -f "$submission_path" -m "$message"
}

finalize_public_score() {
  local candidate_id="$1"
  local submission_path="$2"
  local cv_score="$3"
  local submission_id="$4"

  local submissions_csv="outputs/submissions-after.csv"
  fetch_submissions_csv "$submissions_csv"

  local leaderboard_csv
  leaderboard_csv="$(download_leaderboard_csv)"

  local public_metrics
  public_metrics="$(extract_public_metrics "$leaderboard_csv" "$submissions_csv")"
  local public_rank
  local public_score
  local submission_count
  local public_metrics_timestamp
  public_rank="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read())["public_rank"])' <<<"$public_metrics")"
  public_score="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read())["public_score"])' <<<"$public_metrics")"
  submission_count="$(count_recent_submissions "$submissions_csv")"
  public_metrics_timestamp="$(date +%s)"

  persist_state "$public_rank" "$public_score" "$submission_count" "$submission_path" "$public_metrics_timestamp" "$submission_id" "$candidate_id"
  clear_manifest_overrides
  export MANIFEST_SOURCE_SUBMISSION_FILE="$submission_path"
  write_candidate_manifest "$candidate_id" "public_scored" "" "$cv_score" "$public_metrics_timestamp" "$submission_id"
  clear_manifest_overrides
  remove_queued_candidate "$candidate_id"

  emit_metric "public_rank" "$public_rank"
  emit_metric "public_score" "$public_score"
  emit_metric "cv_score" "$cv_score"
  emit_metric "submission_count" "$submission_count"
  info "candidate_id=${candidate_id}"
  info "submission_id=${submission_id}"
}

start_file_score_pipeline() {
  local candidate_id="$1"
  local submission_path="$2"
  local cv_score="$3"

  local submit_output
  submit_output="$(submit_to_competition "$submission_path" "$cv_score")"
  local submission_id
  submission_id="$(extract_submission_id_from_output "$submit_output")"

  clear_manifest_overrides
  export MANIFEST_SOURCE_SUBMISSION_FILE="$submission_path"
  export MANIFEST_SUBMISSION_ARTIFACT_KIND="file"
  write_candidate_manifest "$candidate_id" "score_request_submitted" "refresh_public_score" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$submission_id"
  clear_manifest_overrides
  remove_queued_candidate "$candidate_id"

  info "candidate_id=${candidate_id}"
  info "submission_id=${submission_id:-pending}"
  info "score_state=score_request_submitted"
  emit_local_metrics "$((CURRENT_SUBMISSION_COUNT + 1))"
}

start_notebook_pipeline() {
  local candidate_id="$1"
  local cv_score="$2"
  local stage_dir
  stage_dir="$(stage_candidate_kernel_dir "$candidate_id")"

  local push_output
  if [[ -n "$KAGGLE_NOTEBOOK_PUSH_CMD" ]]; then
    push_output="$(ROOT_DIR="$ROOT_DIR" COMPETITION_SLUG="$COMPETITION_SLUG" KERNEL_REF="$KERNEL_REF" CANDIDATE_ID="$candidate_id" KAGGLE_STAGE_DIR="$stage_dir" bash -lc "$KAGGLE_NOTEBOOK_PUSH_CMD" 2>&1)"
  else
    push_output="$(kaggle kernels push -p "$stage_dir" 2>&1)"
  fi

  local identity_json
  identity_json="$(resolve_kernel_identity_after_push "$push_output")"
  local kernel_version_id
  local kernel_run_id
  kernel_version_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_version_id",""))' <<<"$identity_json")"
  kernel_run_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_run_id",""))' <<<"$identity_json")"

  [[ -n "$kernel_version_id" ]] || die "Unable to determine the pushed notebook version ID. Configure KAGGLE_NOTEBOOK_IDENTITY_CMD if the CLI output does not expose it."

  clear_manifest_overrides
  export MANIFEST_KERNEL_VERSION_ID="$kernel_version_id"
  export MANIFEST_KERNEL_RUN_ID="$kernel_run_id"
  export MANIFEST_SUBMISSION_ARTIFACT_KIND="$([[ "$COMPETITION_MODE" == "notebook_scored" ]] && printf 'notebook_version' || printf 'file')"
  write_candidate_manifest "$candidate_id" "notebook_run_submitted" "refresh_notebook_run" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(read_state_value "last_submission_id" "")"
  clear_manifest_overrides
  remove_queued_candidate "$candidate_id"

  info "candidate_id=${candidate_id}"
  info "kernel_version_id=${kernel_version_id}"
  info "kernel_run_id=${kernel_run_id:-pending}"
  info "score_state=notebook_run_submitted"
  emit_local_metrics
}

request_notebook_score_for_candidate() {
  local candidate_id="$1"
  local cv_score="$2"
  local kernel_version_id
  local kernel_run_id
  kernel_version_id="$(candidate_manifest_value "$candidate_id" "kernel_version_id" "")"
  kernel_run_id="$(candidate_manifest_value "$candidate_id" "kernel_run_id" "")"
  [[ -n "$kernel_version_id" ]] || die "Cannot request notebook score without kernel_version_id for ${candidate_id}."

  local request_output
  request_output="$(request_notebook_score "$candidate_id" "$kernel_version_id" "$kernel_run_id" "$cv_score")"
  local request_json
  request_json="$(extract_score_request_payload "$request_output")"
  local score_request_id
  local submission_id
  score_request_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("score_request_id",""))' <<<"$request_json")"
  submission_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("submission_id",""))' <<<"$request_json")"

  clear_manifest_overrides
  export MANIFEST_SCORE_REQUEST_ID="$score_request_id"
  export MANIFEST_SCORE_REQUESTED_AT="$(date +%s)"
  export MANIFEST_SUBMISSION_ARTIFACT_KIND="notebook_version"
  write_candidate_manifest "$candidate_id" "score_request_submitted" "refresh_public_score" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$submission_id"
  clear_manifest_overrides

  info "candidate_id=${candidate_id}"
  info "score_request_id=${score_request_id:-pending}"
  info "submission_id=${submission_id:-pending}"
  info "score_state=score_request_submitted"
  emit_local_metrics "$((CURRENT_SUBMISSION_COUNT + 1))"
}

refresh_public_score_for_candidate() {
  local candidate_id="$1"
  local cv_score="$2"
  local submission_path
  local submissions_csv
  local target_submission_id
  local record_json
  local resolved_submission_id
  local scored

  submission_path="$(candidate_submission_file "$candidate_id")"
  submissions_csv="outputs/submissions-after.csv"
  fetch_submissions_csv "$submissions_csv"
  target_submission_id="$(candidate_manifest_value "$candidate_id" "submission_id" "")"
  record_json="$(extract_submission_record "$submissions_csv" "$target_submission_id")"
  resolved_submission_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("submission_id",""))' <<<"$record_json")"
  scored="$(python3 -c 'import json,sys; print("1" if json.loads(sys.stdin.read()).get("scored") else "0")' <<<"$record_json")"

  if [[ "$scored" == "1" ]]; then
    finalize_public_score "$candidate_id" "$submission_path" "$cv_score" "$resolved_submission_id"
    return 0
  fi

  clear_manifest_overrides
  if [[ -n "$resolved_submission_id" ]]; then
    write_candidate_manifest "$candidate_id" "score_pending" "refresh_public_score" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$resolved_submission_id"
  else
    write_candidate_manifest "$candidate_id" "score_request_submitted" "refresh_public_score" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" ""
  fi
  clear_manifest_overrides

  info "candidate_id=${candidate_id}"
  info "submission_id=${resolved_submission_id:-pending}"
  info "score_state=$([[ -n "$resolved_submission_id" ]] && printf 'score_pending' || printf 'score_request_submitted')"
  emit_local_metrics
}

refresh_notebook_candidate() {
  local candidate_id="$1"
  local cv_score="$2"

  if [[ "$(candidate_pending_timed_out "$candidate_id")" == "1" ]]; then
    clear_manifest_overrides
    write_candidate_manifest "$candidate_id" "score_failed" "" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(candidate_manifest_value "$candidate_id" "submission_id" "")"
    clear_manifest_overrides
    info "candidate_id=${candidate_id}"
    info "score_state=score_failed"
    emit_local_metrics
    return 0
  fi

  local status_json
  status_json="$(fetch_kernel_status_once)"
  local kernel_status
  local kernel_version_id
  local kernel_run_id
  kernel_status="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("status","unknown"))' <<<"$status_json")"
  kernel_version_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_version_id",""))' <<<"$status_json")"
  kernel_run_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_run_id",""))' <<<"$status_json")"

  case "$kernel_status" in
    complete)
      clear_manifest_overrides
      export MANIFEST_KERNEL_VERSION_ID="${kernel_version_id:-$(candidate_manifest_value "$candidate_id" "kernel_version_id" "")}"
      export MANIFEST_KERNEL_RUN_ID="${kernel_run_id:-$(candidate_manifest_value "$candidate_id" "kernel_run_id" "")}"
      write_candidate_manifest "$candidate_id" "notebook_run_complete" "$([[ "$COMPETITION_MODE" == "notebook_scored" ]] && printf 'request_score' || printf 'submit_file')" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(candidate_manifest_value "$candidate_id" "submission_id" "")"
      clear_manifest_overrides

      if [[ "$COMPETITION_MODE" == "notebook_scored" ]]; then
        if submission_budget_reached; then
          info "candidate_id=${candidate_id}"
          info "score_state=notebook_run_complete"
          info "pending_next_action=request_score"
          emit_local_metrics "$CURRENT_SUBMISSION_COUNT"
          return 0
        fi
        request_notebook_score_for_candidate "$candidate_id" "$cv_score"
      else
        if submission_budget_reached; then
          info "candidate_id=${candidate_id}"
          info "score_state=notebook_run_complete"
          info "pending_next_action=submit_file"
          emit_local_metrics "$CURRENT_SUBMISSION_COUNT"
          return 0
        fi
        local kernel_submission
        kernel_submission="$(download_kernel_output)"
        start_file_score_pipeline "$candidate_id" "$kernel_submission" "$cv_score"
      fi
      ;;
    failed)
      clear_manifest_overrides
      export MANIFEST_KERNEL_VERSION_ID="${kernel_version_id:-$(candidate_manifest_value "$candidate_id" "kernel_version_id" "")}"
      export MANIFEST_KERNEL_RUN_ID="${kernel_run_id:-$(candidate_manifest_value "$candidate_id" "kernel_run_id" "")}"
      write_candidate_manifest "$candidate_id" "score_failed" "" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(candidate_manifest_value "$candidate_id" "submission_id" "")"
      clear_manifest_overrides
      info "candidate_id=${candidate_id}"
      info "score_state=score_failed"
      emit_local_metrics
      ;;
    *)
      clear_manifest_overrides
      export MANIFEST_KERNEL_VERSION_ID="${kernel_version_id:-$(candidate_manifest_value "$candidate_id" "kernel_version_id" "")}"
      export MANIFEST_KERNEL_RUN_ID="${kernel_run_id:-$(candidate_manifest_value "$candidate_id" "kernel_run_id" "")}"
      write_candidate_manifest "$candidate_id" "notebook_run_running" "refresh_notebook_run" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(candidate_manifest_value "$candidate_id" "submission_id" "")"
      clear_manifest_overrides
      info "candidate_id=${candidate_id}"
      info "score_state=notebook_run_running"
      emit_local_metrics
      ;;
  esac
}

refresh_candidate_score() {
  local candidate_id="$1"
  local score_state
  local cv_score
  score_state="$(candidate_manifest_value "$candidate_id" "score_state" "unknown")"
  cv_score="$(candidate_metric_value "$candidate_id" "cv_score" "$(read_metrics_value "cv_score" "0")")"

  case "$score_state" in
    pending_submission)
      if submission_budget_reached; then
        info "candidate_id=${candidate_id}"
        info "score_state=pending_submission"
        emit_local_metrics "$CURRENT_SUBMISSION_COUNT"
        return 0
      fi
      if [[ "$COMPETITION_MODE" == "file_upload" ]]; then
        start_file_score_pipeline "$candidate_id" "$(candidate_submission_file "$candidate_id")" "$cv_score"
      else
        start_notebook_pipeline "$candidate_id" "$cv_score"
      fi
      ;;
    notebook_run_submitted|notebook_run_running)
      refresh_notebook_candidate "$candidate_id" "$cv_score"
      ;;
    notebook_run_complete)
      if [[ "$COMPETITION_MODE" == "notebook_scored" ]]; then
        if submission_budget_reached; then
          info "candidate_id=${candidate_id}"
          info "score_state=notebook_run_complete"
          info "pending_next_action=request_score"
          emit_local_metrics "$CURRENT_SUBMISSION_COUNT"
          return 0
        fi
        request_notebook_score_for_candidate "$candidate_id" "$cv_score"
      else
        if submission_budget_reached; then
          info "candidate_id=${candidate_id}"
          info "score_state=notebook_run_complete"
          info "pending_next_action=submit_file"
          emit_local_metrics "$CURRENT_SUBMISSION_COUNT"
          return 0
        fi
        local kernel_submission
        kernel_submission="$(download_kernel_output)"
        start_file_score_pipeline "$candidate_id" "$kernel_submission" "$cv_score"
      fi
      ;;
    score_request_submitted|score_pending)
      refresh_public_score_for_candidate "$candidate_id" "$cv_score"
      ;;
    score_failed|public_scored|local_only|quota_exhausted|unknown)
      info "candidate_id=${candidate_id}"
      info "score_state=${score_state}"
      emit_local_metrics
      ;;
    *)
      die "Unsupported candidate score_state=${score_state} for ${candidate_id}"
      ;;
  esac
}

local_only_mode() {
  local candidate_id="$1"
  run_local_pipeline >&2
  local cv_score
  cv_score="$(read_metrics_value "cv_score" "0")"
  clear_manifest_overrides
  export MANIFEST_SUBMISSION_ARTIFACT_KIND="file"
  write_candidate_manifest "$candidate_id" "local_only" "" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(read_state_value "last_submission_id" "")"
  clear_manifest_overrides
  info "candidate_id=${candidate_id}"
  emit_local_metrics
}

prepare_submission_candidate() {
  local requested_candidate_id="$1"
  local candidate_id="$requested_candidate_id"

  if [[ -n "$candidate_id" && -f "$(candidate_manifest_path "$candidate_id")" ]]; then
    printf '%s\n' "$candidate_id"
    return 0
  fi

  if [[ -z "$candidate_id" ]]; then
    candidate_id="$(select_best_pending_candidate)"
    if [[ -n "$candidate_id" && -f "$(candidate_manifest_path "$candidate_id")" ]]; then
      printf '%s\n' "$candidate_id"
      return 0
    fi
  fi

  candidate_id="$(resolve_candidate_id "${requested_candidate_id:-${CANDIDATE_ID:-}}")"
  run_local_pipeline >&2
  local cv_score
  cv_score="$(read_metrics_value "cv_score" "0")"
  clear_manifest_overrides
  export MANIFEST_SUBMISSION_ARTIFACT_KIND="file"
  write_candidate_manifest "$candidate_id" "pending_submission" "submit_candidate" "$cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(read_state_value "last_submission_id" "")"
  clear_manifest_overrides
  printf '%s\n' "$candidate_id"
}

submit_mode() {
  local requested_candidate_id="${1:-}"
  require_cmd kaggle
  require_kaggle_auth
  verify_competition_access

  local active_candidate_id
  active_candidate_id="$(select_active_score_candidate)"
  if [[ -n "$active_candidate_id" && ( -z "$requested_candidate_id" || "$requested_candidate_id" == "$active_candidate_id" ) ]]; then
    refresh_candidate_score "$active_candidate_id"
    return 0
  fi

  if submission_budget_reached; then
    local queued_candidate_id="$requested_candidate_id"
    if [[ -z "$queued_candidate_id" ]]; then
      queued_candidate_id="$(select_best_pending_candidate)"
    fi
    if [[ -z "$queued_candidate_id" || ! -f "$(candidate_manifest_path "$queued_candidate_id")" ]]; then
      queued_candidate_id="$(resolve_candidate_id "${requested_candidate_id:-${CANDIDATE_ID:-}}")"
      run_local_pipeline
      local queued_cv_score
      queued_cv_score="$(read_metrics_value "cv_score" "0")"
      clear_manifest_overrides
      export MANIFEST_SUBMISSION_ARTIFACT_KIND="file"
      write_candidate_manifest "$queued_candidate_id" "quota_exhausted" "" "$queued_cv_score" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(read_state_value "last_submission_id" "")"
      clear_manifest_overrides
    fi
    handle_submission_budget_pause "$queued_candidate_id"
    return 0
  fi

  local candidate_id
  candidate_id="$(prepare_submission_candidate "$requested_candidate_id")"
  local cv_score
  cv_score="$(candidate_metric_value "$candidate_id" "cv_score" "$(read_metrics_value "cv_score" "0")")"

  case "$COMPETITION_MODE" in
    file_upload)
      start_file_score_pipeline "$candidate_id" "$(candidate_submission_file "$candidate_id")" "$cv_score"
      ;;
    notebook_scored|hybrid)
      start_notebook_pipeline "$candidate_id" "$cv_score"
      ;;
    *)
      die "Unsupported COMPETITION_MODE=${COMPETITION_MODE}"
      ;;
  esac
}

refresh_score_mode() {
  local target="${1:-}"
  require_cmd kaggle
  require_kaggle_auth
  verify_competition_access

  local targets=()
  if [[ "$target" == "--all-pending" ]]; then
    mapfile -t targets < <(list_pending_score_candidates)
  elif [[ -n "$target" ]]; then
    targets=("$(normalize_candidate_id "$target")")
  else
    local active_candidate_id
    active_candidate_id="$(select_active_score_candidate)"
    if [[ -n "$active_candidate_id" ]]; then
      targets=("$active_candidate_id")
    fi
  fi

  if [[ ${#targets[@]} -eq 0 ]]; then
    info "no_pending_score_work=1"
    emit_local_metrics
    return 0
  fi

  local candidate_id
  for candidate_id in "${targets[@]}"; do
    refresh_candidate_score "$candidate_id"
  done
}

merge_candidates_mode() {
  local merge_inputs="$1"
  local candidate_id
  candidate_id="$(resolve_candidate_id "${CANDIDATE_ID:-merge-${merge_inputs//,/--}}")"

  python3 - "$CANDIDATES_DIR" "$merge_inputs" "$SUBMISSION_FILE" "$METRICS_FILE" "$CV_DIRECTION" <<'PY'
import csv
import json
import shutil
import sys
from pathlib import Path

candidate_root = Path(sys.argv[1])
merge_inputs = [item for item in sys.argv[2].split(",") if item]
submission_path = Path(sys.argv[3])
metrics_path = Path(sys.argv[4])
cv_direction = (sys.argv[5] or "higher").strip().lower()

if len(merge_inputs) < 2:
    raise SystemExit("Need at least two candidate IDs to merge.")

manifests = []
for candidate_id in merge_inputs:
    manifest_path = candidate_root / candidate_id / "manifest.json"
    if not manifest_path.exists():
        raise SystemExit(f"Missing candidate manifest: {manifest_path}")
    manifests.append(json.loads(manifest_path.read_text()))

submission_files = [Path(manifest["submission_file"]) for manifest in manifests]
for candidate in submission_files:
    if not candidate.exists():
        raise SystemExit(f"Missing submission file for merge: {candidate}")

rows_per_file = []
headers = None
for submission_file in submission_files:
    rows = list(csv.DictReader(submission_file.open(newline="")))
    if not rows:
        raise SystemExit(f"Submission file was empty: {submission_file}")
    if headers is None:
        headers = list(rows[0].keys())
    elif headers != list(rows[0].keys()):
        raise SystemExit("Submission files have mismatched schemas and cannot be merged safely.")
    rows_per_file.append(rows)

id_key = headers[0]
target_keys = headers[1:]
if not target_keys:
    raise SystemExit("Submission merge requires at least one prediction column.")

numeric = True
for rows in rows_per_file:
    for row in rows:
        for key in target_keys:
            try:
                float(row[key])
            except Exception:
                numeric = False
                break
        if not numeric:
            break
    if not numeric:
        break

submission_path.parent.mkdir(parents=True, exist_ok=True)
if not numeric:
    shutil.copyfile(submission_files[0], submission_path)
else:
    with submission_path.open("w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=headers)
        writer.writeheader()
        for row_idx in range(len(rows_per_file[0])):
            merged = {id_key: rows_per_file[0][row_idx][id_key]}
            for key in target_keys:
                values = [float(rows[row_idx][key]) for rows in rows_per_file]
                merged[key] = f"{sum(values) / len(values):.10f}"
            writer.writerow(merged)

best_manifest = max(
    manifests,
    key=lambda manifest: manifest.get("metrics", {}).get("cv_score", float("-inf"))
    if cv_direction == "higher"
    else -manifest.get("metrics", {}).get("cv_score", float("inf")),
)
metrics = dict(best_manifest.get("metrics") or {})
metrics["merge_candidate_count"] = len(merge_inputs)
metrics_path.parent.mkdir(parents=True, exist_ok=True)
metrics_path.write_text(json.dumps(metrics, indent=2) + "\n")
PY

  clear_manifest_overrides
  export MANIFEST_SOURCE_SUBMISSION_FILE="$SUBMISSION_FILE"
  export MANIFEST_SUBMISSION_ARTIFACT_KIND="file"
  write_candidate_manifest "$candidate_id" "local_only" "" "$(read_metrics_value "cv_score" "0")" "$(read_state_value "last_public_metrics_timestamp" "0")" "$(read_state_value "last_submission_id" "")" "$merge_inputs"
  clear_manifest_overrides
  info "merged_candidate_id=${candidate_id}"
  emit_local_metrics
}

load_env_file_if_present
resolve_leaderboard_team_name
ensure_state_file
normalize_competition_mode

case "$MODE" in
  --local-only)
    local_only_mode "$(resolve_candidate_id "${MODE_ARG:-${CANDIDATE_ID:-}}")"
    ;;
  --submit)
    submit_mode "${MODE_ARG:-}"
    ;;
  --submit-candidate)
    [[ -n "$MODE_ARG" ]] || die "--submit-candidate requires a candidate ID."
    submit_mode "$(normalize_candidate_id "$MODE_ARG")"
    ;;
  --refresh-score)
    refresh_score_mode "${MODE_ARG:-}"
    ;;
  --merge-candidates)
    [[ -n "$MODE_ARG" ]] || die "--merge-candidates requires a comma-separated candidate ID list."
    merge_candidates_mode "$MODE_ARG"
    ;;
  *)
    die "Unsupported mode: $MODE. Use --local-only, --submit, --submit-candidate, --refresh-score, or --merge-candidates."
    ;;
esac
