}

normalize_candidate_id() {
  local raw="${1:-}"
  python3 - "$raw" <<'PY'
import re
import sys

value = (sys.argv[1] or "").strip().lower()
value = re.sub(r"[^a-z0-9._-]+", "-", value)
value = re.sub(r"-{2,}", "-", value).strip("-")
print(value or "candidate")
PY
}

resolve_candidate_id() {
  local preferred="${1:-}"
  if [[ -n "$preferred" ]]; then
    normalize_candidate_id "$preferred"
    return 0
  fi

  local git_sha="nogit"
  if command -v git >/dev/null 2>&1; then
    git_sha="$(git rev-parse --short HEAD 2>/dev/null || printf 'nogit')"
  fi
  normalize_candidate_id "${COMPETITION_SLUG}-${git_sha}-$(date +%Y%m%d%H%M%S)"
}

candidate_dir() {
  local candidate_id
  candidate_id="$(normalize_candidate_id "$1")"
  printf '%s/%s\n' "$CANDIDATES_DIR" "$candidate_id"
}

candidate_manifest_path() {
  local candidate_id
  candidate_id="$(normalize_candidate_id "$1")"
  printf '%s/manifest.json\n' "$(candidate_dir "$candidate_id")"
}

candidate_manifest_value() {
  local candidate_id="$1"
  local key="$2"
  local default_value="$3"
  python3 - "$(candidate_manifest_path "$candidate_id")" "$key" "$default_value" <<'PY'
import json
import sys
from pathlib import Path

manifest_path = Path(sys.argv[1])
key = sys.argv[2]
default_value = sys.argv[3]
if not manifest_path.exists():
    print(default_value)
    raise SystemExit(0)

payload = json.loads(manifest_path.read_text())
value = payload.get(key, default_value)
if value is None:
    value = default_value
if isinstance(value, (dict, list)):
    print(json.dumps(value))
else:
    print(value)
PY
}

candidate_submission_file() {
  candidate_manifest_value "$1" "submission_file" "$SUBMISSION_FILE"
}

candidate_metric_value() {
  local candidate_id="$1"
  local metric_key="$2"
  local default_value="$3"
  python3 - "$(candidate_manifest_path "$candidate_id")" "$metric_key" "$default_value" <<'PY'
import json
import sys
from pathlib import Path

manifest_path = Path(sys.argv[1])
metric_key = sys.argv[2]
default_value = sys.argv[3]
if not manifest_path.exists():
    print(default_value)
    raise SystemExit(0)

payload = json.loads(manifest_path.read_text())
metrics = payload.get("metrics") or {}
value = metrics.get(metric_key, payload.get(metric_key, default_value))
if value is None:
    value = default_value
if isinstance(value, (dict, list)):
    print(json.dumps(value))
else:
    print(value)
PY
}

clear_manifest_overrides() {
  unset MANIFEST_SOURCE_SUBMISSION_FILE || true
  unset MANIFEST_SOURCE_NOTEBOOK_FILE || true
  unset MANIFEST_SOURCE_METRICS_FILE || true
  unset MANIFEST_SUBMISSION_ARTIFACT_KIND || true
  unset MANIFEST_KERNEL_VERSION_ID || true
  unset MANIFEST_KERNEL_RUN_ID || true
  unset MANIFEST_SCORE_REQUEST_ID || true
  unset MANIFEST_SCORE_REQUESTED_AT || true
  unset MANIFEST_KERNEL_REF || true
}

write_candidate_manifest() {
  local candidate_id="$1"
  local score_state="$2"
  local pending_next_action="${3:-}"
  local pending_priority="${4:-}"
  local public_metrics_timestamp="${5:-}"
  local submission_id="${6:-}"
  local merge_inputs="${7:-}"
  local candidate_path
  candidate_path="$(candidate_dir "$candidate_id")"
  mkdir -p "$candidate_path"

  python3 - \
    "$(candidate_manifest_path "$candidate_id")" \
    "$candidate_id" \
    "$score_state" \
    "$pending_next_action" \
    "$pending_priority" \
    "$public_metrics_timestamp" \
    "$submission_id" \
    "$merge_inputs" \
    "$ROOT_DIR" \
    "$NOTEBOOK_IPYNB" \
    "$METRICS_FILE" \
    "$SUBMISSION_FILE" \
    "$COMPETITION_MODE" \
    "$KAGGLE_SCORE_BACKEND" \
    "$KERNEL_REF" \
    <<'PY'
import json
import os
import shutil
import sys
import time
from pathlib import Path

manifest_path = Path(sys.argv[1])
candidate_id = sys.argv[2]
score_state = sys.argv[3]
pending_next_action = sys.argv[4]
pending_priority = sys.argv[5]
public_metrics_timestamp = sys.argv[6]
submission_id = sys.argv[7]
merge_inputs = [item for item in sys.argv[8].split(",") if item]
root_dir = Path(sys.argv[9]).resolve()
notebook_ipynb = sys.argv[10]
metrics_file = sys.argv[11]
submission_file = sys.argv[12]
competition_mode = sys.argv[13]
score_backend = sys.argv[14]
kernel_ref = sys.argv[15]

payload = {}
if not manifest_path.is_absolute():
    manifest_path = (root_dir / manifest_path).resolve()
if manifest_path.exists():
    payload = json.loads(manifest_path.read_text())

state = {}
state_path = root_dir / os.environ.get("STATE_FILE", "outputs/kaggle_state.json")
if state_path.exists():
    state = json.loads(state_path.read_text())

metrics = {}
metrics_path = root_dir / metrics_file
if metrics_path.exists():
    metrics = json.loads(metrics_path.read_text())

candidate_dir = manifest_path.parent
artifacts_dir = candidate_dir / "artifacts"
artifacts_dir.mkdir(parents=True, exist_ok=True)

def maybe_copy(source_value: str):
    if not source_value:
        return None
    source = Path(source_value)
    if not source.is_absolute():
        source = root_dir / source
    if not source.exists():
        return None
    destination = artifacts_dir / source.name
    if source.resolve() != destination.resolve():
        shutil.copyfile(source, destination)
    return destination.relative_to(root_dir).as_posix()

copied_submission = maybe_copy(os.environ.get("MANIFEST_SOURCE_SUBMISSION_FILE") or submission_file)
copied_notebook = maybe_copy(os.environ.get("MANIFEST_SOURCE_NOTEBOOK_FILE") or notebook_ipynb)
copied_metrics = maybe_copy(os.environ.get("MANIFEST_SOURCE_METRICS_FILE") or metrics_file)

artifact_paths = list(payload.get("artifact_paths") or [])
for value in (copied_submission, copied_notebook, copied_metrics):
    if value and value not in artifact_paths:
        artifact_paths.append(value)

score_requested_at = os.environ.get("MANIFEST_SCORE_REQUESTED_AT") or payload.get("score_requested_at")
if score_requested_at not in (None, "", "null"):
    score_requested_at = int(float(score_requested_at))
else:
    score_requested_at = None

pending_priority_value = payload.get("pending_priority")
if pending_priority not in ("", None):
    pending_priority_value = float(pending_priority)

public_metrics_ts_value = payload.get("public_metrics_timestamp")
if public_metrics_timestamp not in ("", "0", None):
    public_metrics_ts_value = int(float(public_metrics_timestamp))

payload.update(
    {
        "candidate_id": candidate_id,
        "updated_at": int(time.time()),
        "score_state": score_state,
        "competition_mode": competition_mode,
        "score_backend": score_backend,
        "kernel_ref": os.environ.get("MANIFEST_KERNEL_REF") or payload.get("kernel_ref") or kernel_ref,
        "kernel_version_id": os.environ.get("MANIFEST_KERNEL_VERSION_ID") or payload.get("kernel_version_id"),
        "kernel_run_id": os.environ.get("MANIFEST_KERNEL_RUN_ID") or payload.get("kernel_run_id"),
        "score_request_id": os.environ.get("MANIFEST_SCORE_REQUEST_ID") or payload.get("score_request_id"),
        "score_requested_at": score_requested_at,
        "submission_artifact_kind": os.environ.get("MANIFEST_SUBMISSION_ARTIFACT_KIND")
        or payload.get("submission_artifact_kind")
        or ("notebook_version" if competition_mode == "notebook_scored" else "file"),
        "pending_next_action": pending_next_action or None,
        "metrics": metrics or payload.get("metrics", {}),
        "submission_file": copied_submission or payload.get("submission_file") or submission_file,
        "notebook_ipynb": copied_notebook or payload.get("notebook_ipynb") or notebook_ipynb,
        "metrics_file": copied_metrics or payload.get("metrics_file") or metrics_file,
        "local_accelerator": os.environ.get("LOCAL_ACCELERATOR", "cpu"),
        "public_rank": state.get("public_rank"),
        "public_score": state.get("public_score"),
        "submission_count": state.get("submission_count"),
        "public_metrics_timestamp": public_metrics_ts_value,
        "submission_id": submission_id or payload.get("submission_id"),
        "merge_inputs": merge_inputs or payload.get("merge_inputs", []),
        "pending_priority": pending_priority_value,
        "artifact_paths": artifact_paths,
    }
)
payload.setdefault("created_at", int(time.time()))

manifest_path.write_text(json.dumps(payload, indent=2) + "\n")
PY
}

stage_candidate_kernel_dir() {
  local candidate_id="$1"
  python3 - "$(candidate_manifest_path "$candidate_id")" "$ROOT_DIR" "$NOTEBOOK_IPYNB" <<'PY'
import json
import shutil
import sys
from pathlib import Path

manifest_path = Path(sys.argv[1])
root_dir = Path(sys.argv[2])
notebook_name = Path(sys.argv[3]).name
if not manifest_path.exists():
    raise SystemExit(f"Missing candidate manifest: {manifest_path}")

payload = json.loads(manifest_path.read_text())
notebook_path = payload.get("notebook_ipynb")
if not notebook_path:
    raise SystemExit("Candidate manifest is missing notebook_ipynb.")

source_notebook = Path(notebook_path)
if not source_notebook.is_absolute():
    source_notebook = root_dir / source_notebook
if not source_notebook.exists():
    raise SystemExit(f"Missing candidate notebook snapshot: {source_notebook}")

stage_dir = manifest_path.parent / "kernel-staging"
stage_dir.mkdir(parents=True, exist_ok=True)
shutil.copyfile(source_notebook, stage_dir / notebook_name)

metadata_path = root_dir / "kernel-metadata.json"
if metadata_path.exists():
    shutil.copyfile(metadata_path, stage_dir / "kernel-metadata.json")

print(stage_dir)
PY
}

validate_runtime_budget() {
  python3 - "$METRICS_FILE" "$NOTEBOOK_RUNTIME_BUDGET_SECONDS" "$NOTEBOOK_RUNTIME_LIMIT_SECONDS" "$NOTEBOOK_RUNTIME_SAFETY_MARGIN_SECONDS" <<'PY'
import json
import sys
from pathlib import Path

metrics_path = Path(sys.argv[1])
budget = float(sys.argv[2])
limit = float(sys.argv[3])
margin = float(sys.argv[4])

if not metrics_path.exists():
    raise SystemExit(f"Missing metrics file: {metrics_path}")

payload = json.loads(metrics_path.read_text())
wall_clock = payload.get("wall_clock_seconds")
if wall_clock is None:
    raise SystemExit(
        "Missing wall_clock_seconds in metrics.json. "
        "The notebook must report runtime so preflight can enforce the Kaggle time budget."
    )

wall_clock = float(wall_clock)
if wall_clock > budget:
    raise SystemExit(
        "Notebook runtime budget exceeded: "
        f"wall_clock_seconds={wall_clock:.3f}, "
        f"budget_seconds={budget:.3f}, "
        f"limit_seconds={limit:.3f}, "
        f"safety_margin_seconds={margin:.3f}"
    )
PY
}

require_kaggle_auth() {
  local config_dir="${KAGGLE_CONFIG_DIR:-$HOME/.kaggle}"
  local legacy_json_path="${config_dir}/kaggle.json"
  load_kaggle_auth
  resolve_leaderboard_team_name

  if [[ -n "${KAGGLE_API_TOKEN:-}" || -n "${KAGGLE_KEY:-}" ]]; then
    return 0
  fi

  if [[ -f "$legacy_json_path" ]]; then
    return 0
  fi

  die "Missing Kaggle credentials. Supported sources: ${KAGGLE_ENV_FILE:-.env} with KAGGLE_API_TOKEN, KAGGLE_TOKEN_FILE or access_token, or legacy ${legacy_json_path}."
}

verify_competition_access() {
  if ! kaggle competitions files "$COMPETITION_SLUG" -q >/dev/null 2>&1; then
    die "Unable to access ${COMPETITION_SLUG}. Authenticate the Kaggle CLI and accept the competition rules at ${COMPETITION_URL}/rules."
  fi
}

run_local_pipeline() {
  require_cmd python3
  prepare_local_accelerator
  python3 build_notebook.py --input "$NOTEBOOK_SRC" --output "$NOTEBOOK_IPYNB" >/dev/null

  local log_file="outputs/local-run.log"
  set +e
  bash -lc "$LOCAL_RUN_CMD" 2>&1 | tee "$log_file"
  local status=${PIPESTATUS[0]}
  set -e

  [[ $status -eq 0 ]] || die "Local run failed with exit code ${status}."
  [[ -f "$METRICS_FILE" ]] || die "Local run did not create metrics file: $METRICS_FILE"
  [[ -f "$SUBMISSION_FILE" ]] || die "Local run did not create submission artifact: $SUBMISSION_FILE"
  validate_runtime_budget
}

fetch_submissions_csv() {
  local output_path="$1"
  kaggle competitions submissions "$COMPETITION_SLUG" -v -q >"$output_path"
}

count_recent_submissions() {
  local submissions_csv="$1"
  python3 - "$submissions_csv" <<'PY'
import csv
import datetime as dt
import sys
from pathlib import Path

path = Path(sys.argv[1])
if not path.exists():
    print(0)
    raise SystemExit(0)

rows = list(csv.DictReader(path.open(newline="")))
if not rows:
    print(0)
    raise SystemExit(0)

date_key = next((key for key in rows[0].keys() if "date" in key.lower() or "time" in key.lower()), None)
if not date_key:
    print(len(rows))
    raise SystemExit(0)

today = dt.datetime.now().date()
count = 0
parsed_any = False
for row in rows:
    raw = (row.get(date_key) or "").strip()
    if not raw:
        continue
    candidate = raw.replace("Z", "+00:00")
    parsed = None
    for parser in (
        lambda value: dt.datetime.fromisoformat(value),
        lambda value: dt.datetime.strptime(value, "%Y-%m-%d %H:%M:%S"),
        lambda value: dt.datetime.strptime(value, "%Y-%m-%d"),
    ):
        try:
            parsed = parser(candidate)
            break
        except ValueError:
            continue
    if parsed is None:
        continue
    parsed_any = True
    if parsed.date() == today:
        count += 1

print(count if parsed_any else len(rows))
PY
}

submission_budget_reached() {
  local submissions_csv="outputs/submissions-before.csv"
  fetch_submissions_csv "$submissions_csv"
  CURRENT_SUBMISSION_COUNT="$(count_recent_submissions "$submissions_csv")"

  [[ "$MAX_DAILY_SUBMISSIONS" =~ ^[0-9]+$ ]] || die "MAX_DAILY_SUBMISSIONS must be numeric, got: ${MAX_DAILY_SUBMISSIONS}"
  [[ "$CURRENT_SUBMISSION_COUNT" =~ ^[0-9]+$ ]] || CURRENT_SUBMISSION_COUNT="0"

  if (( CURRENT_SUBMISSION_COUNT >= MAX_DAILY_SUBMISSIONS )); then
    return 0
  fi

  return 1
}

download_kernel_output() {
  local output_dir="${1:-$KERNEL_OUTPUT_DIR}"
  rm -rf "$output_dir"
  mkdir -p "$output_dir"
  kaggle kernels output "$KERNEL_REF" -p "$output_dir" -o -q >/dev/null

  local submission_name
  submission_name="$(basename "$SUBMISSION_FILE")"
  local kernel_submission="${output_dir}/${submission_name}"
  [[ -f "$kernel_submission" ]] || die "Kernel outputs did not contain ${submission_name}."
  echo "$kernel_submission"
}

download_leaderboard_csv() {
  kaggle competitions leaderboard "$COMPETITION_SLUG" -d -p "$KERNEL_OUTPUT_DIR" -q >/dev/null
  local leaderboard_file
  leaderboard_file="$(find "$KERNEL_OUTPUT_DIR" -maxdepth 1 -type f -iname '*leaderboard*' | sort | tail -n 1)"
  [[ -n "$leaderboard_file" ]] || die "Leaderboard download file not found in ${KERNEL_OUTPUT_DIR}."
  echo "$leaderboard_file"
}

extract_public_metrics() {
  local leaderboard_csv="$1"
  local submissions_csv="$2"
  python3 - "$leaderboard_csv" "$submissions_csv" "$LEADERBOARD_TEAM_NAME" "$KERNEL_OWNER" <<'PY'
import csv
import json
import sys
from pathlib import Path

leaderboard_path = Path(sys.argv[1])
submissions_path = Path(sys.argv[2])
expected_names = {name.strip().casefold() for name in sys.argv[3:] if name.strip()}

if not leaderboard_path.exists():
    raise SystemExit("Missing leaderboard download.")

leaderboard_rows = list(csv.DictReader(leaderboard_path.open(newline="")))
if not leaderboard_rows:
    raise SystemExit("Leaderboard download was empty.")

rank_key = next((key for key in leaderboard_rows[0] if "rank" in key.lower()), None)
score_key = next((key for key in leaderboard_rows[0] if "score" in key.lower()), None)
name_keys = [key for key in leaderboard_rows[0] if any(token in key.lower() for token in ("team", "user", "name", "display"))]

if not rank_key or not score_key or not name_keys:
    raise SystemExit("Could not infer leaderboard columns for rank, score, and team name.")

match = None
for row in leaderboard_rows:
    values = {(row.get(key) or "").strip().casefold() for key in name_keys}
    if values & expected_names:
        match = row
        break

if match is None:
    raise SystemExit(
        "Could not find the configured team on the downloaded leaderboard. "
        "Set LEADERBOARD_TEAM_NAME to the exact team or display name used on the leaderboard."
    )

submissions_rows = []
if submissions_path.exists():
    submissions_rows = list(csv.DictReader(submissions_path.open(newline="")))

latest_score = None
if submissions_rows:
    submission_score_key = next((key for key in submissions_rows[0] if "score" in key.lower()), None)
    if submission_score_key:
        latest_score = submissions_rows[0].get(submission_score_key)

payload = {
    "public_rank": float(match[rank_key]),
    "public_score": float(latest_score if latest_score not in (None, "") else match[score_key]),
}
print(json.dumps(payload))
PY
}

extract_submission_record() {
  local submissions_csv="$1"
  local target_submission_id="${2:-}"
  python3 - "$submissions_csv" "$target_submission_id" <<'PY'
import csv
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
target_id = sys.argv[2]
if not path.exists():
    print(json.dumps({"found": False}))
    raise SystemExit(0)

rows = list(csv.DictReader(path.open(newline="")))
if not rows:
    print(json.dumps({"found": False}))
    raise SystemExit(0)

id_key = next((key for key in rows[0].keys() if "id" in key.lower()), None)
score_key = next((key for key in rows[0].keys() if "score" in key.lower()), None)
status_key = next((key for key in rows[0].keys() if "status" in key.lower()), None)

matched = None
if target_id and id_key:
    for row in rows:
        if (row.get(id_key) or "").strip() == target_id:
            matched = row
            break
if matched is None:
    matched = rows[0]

submission_id = (matched.get(id_key) or "").strip() if id_key else ""
score_raw = (matched.get(score_key) or "").strip() if score_key else ""
status = (matched.get(status_key) or "").strip() if status_key else ""
scored = score_raw not in ("", None)

payload = {
    "found": matched is not None,
    "submission_id": submission_id,
    "score": score_raw,
    "status": status,
    "scored": scored,
}
print(json.dumps(payload))
PY
}

extract_submission_id_from_output() {
  local output="$1"
  python3 - "$output" <<'PY'
import json
import re
import sys

text = sys.argv[1]
value = None
try:
    payload = json.loads(text)
    if isinstance(payload, dict):
        value = payload.get("submission_id") or payload.get("id")
except Exception:
    pass

if not value:
    match = re.search(r"(sub-[A-Za-z0-9._-]+)", text)
    if match:
        value = match.group(1)

print(value or "")
PY
}

parse_kernel_status_payload() {
  local raw_payload="$1"
  python3 - "$raw_payload" <<'PY'
import json
import re
import sys

text = sys.argv[1].strip()
payload = {}

try:
    parsed = json.loads(text)
    if isinstance(parsed, dict):
        payload = parsed
except Exception:
    payload = {}

status = (
    payload.get("status")
    or payload.get("kernel_status")
    or payload.get("run_status")
    or text
)
status_text = str(status).lower()
normalized = "unknown"
if any(token in status_text for token in ("complete", "finished", "success", "done")):
    normalized = "complete"
elif any(token in status_text for token in ("fail", "error", "cancel", "invalid")):
    normalized = "failed"
elif any(token in status_text for token in ("run", "queue", "pending", "submit", "starting")):
    normalized = "running"

kernel_version_id = (
    payload.get("kernel_version_id")
    or payload.get("version_id")
    or payload.get("versionId")
    or ""
)
kernel_run_id = (
    payload.get("kernel_run_id")
    or payload.get("run_id")
    or payload.get("runId")
    or ""
)

if not kernel_version_id:
    match = re.search(r"(kv-[A-Za-z0-9._-]+|version[_-]?id[:= ]+([A-Za-z0-9._-]+))", text, re.I)
    if match:
        kernel_version_id = match.group(1) if match.group(1).startswith("kv-") else match.group(2)
if not kernel_run_id:
    match = re.search(r"(kr-[A-Za-z0-9._-]+|run[_-]?id[:= ]+([A-Za-z0-9._-]+))", text, re.I)
    if match:
        kernel_run_id = match.group(1) if match.group(1).startswith("kr-") else match.group(2)

print(json.dumps({
    "status": normalized,
    "kernel_version_id": kernel_version_id,
    "kernel_run_id": kernel_run_id,
    "raw": text,
}))
PY
}

fetch_kernel_status_once() {
  local output
  output="$(kaggle kernels status "$KERNEL_REF" 2>&1 | tr -d '\r')"
  parse_kernel_status_payload "$output"
}

resolve_kernel_identity_after_push() {
  local push_output="$1"
  local parsed
  parsed="$(parse_kernel_status_payload "$push_output")"
  local kernel_version_id
  local kernel_run_id
  kernel_version_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_version_id",""))' <<<"$parsed")"
  kernel_run_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_run_id",""))' <<<"$parsed")"

  if [[ -z "$kernel_version_id" || -z "$kernel_run_id" ]]; then
    if [[ -n "$KAGGLE_NOTEBOOK_IDENTITY_CMD" ]]; then
      parsed="$(ROOT_DIR="$ROOT_DIR" COMPETITION_SLUG="$COMPETITION_SLUG" KERNEL_REF="$KERNEL_REF" bash -lc "$KAGGLE_NOTEBOOK_IDENTITY_CMD")"
      kernel_version_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_version_id",""))' <<<"$parsed")"
      kernel_run_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_run_id",""))' <<<"$parsed")"
    else
      parsed="$(fetch_kernel_status_once)"
      kernel_version_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_version_id",""))' <<<"$parsed")"
      kernel_run_id="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("kernel_run_id",""))' <<<"$parsed")"
    fi
  fi

  python3 - "$kernel_version_id" "$kernel_run_id" <<'PY'
import json
import sys

print(json.dumps({
    "kernel_version_id": sys.argv[1],
    "kernel_run_id": sys.argv[2],
}))
PY
}

request_notebook_score() {
  local candidate_id="$1"
  local kernel_version_id="$2"
  local kernel_run_id="$3"
  local cv_score="$4"

  CANDIDATE_ID="$candidate_id" \
  COMPETITION_SLUG="$COMPETITION_SLUG" \
  KERNEL_REF="$KERNEL_REF" \
  KERNEL_VERSION_ID="$kernel_version_id" \
  KERNEL_RUN_ID="$kernel_run_id" \
  CV_SCORE="$cv_score" \
  bash -lc "$KAGGLE_NOTEBOOK_SCORE_CMD" || die "Notebook score request failed. Override KAGGLE_NOTEBOOK_SCORE_CMD if this competition needs a different Kaggle-native scoring call."
}

extract_score_request_payload() {
  local raw_payload="$1"
  python3 - "$raw_payload" <<'PY'
import json
import re
import sys

text = sys.argv[1].strip()
payload = {}
try:
    parsed = json.loads(text)
    if isinstance(parsed, dict):
        payload = parsed
except Exception:
    payload = {}

score_request_id = payload.get("score_request_id") or payload.get("request_id") or ""
submission_id = payload.get("submission_id") or payload.get("id") or ""

if not score_request_id:
    match = re.search(r"(req-[A-Za-z0-9._-]+)", text)
    if match:
        score_request_id = match.group(1)
if not submission_id:
    match = re.search(r"(sub-[A-Za-z0-9._-]+)", text)
    if match:
