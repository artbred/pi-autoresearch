case "$MODE" in
  --local-only)
    local_only_mode "$(resolve_candidate_id "${MODE_ARG:-${CANDIDATE_ID:-}}")"
    ;;
  --submit)
    submit_mode ""
    ;;
  --submit-candidate)
    [[ -n "$MODE_ARG" ]] || die "--submit-candidate requires a candidate ID."
    submit_mode "$(normalize_candidate_id "$MODE_ARG")"
    ;;
  --merge-candidates)
    [[ -n "$MODE_ARG" ]] || die "--merge-candidates requires a comma-separated candidate ID list."
    merge_candidates_mode "$MODE_ARG"
    ;;
  *)
    die "Unsupported mode: $MODE. Use --local-only, --submit, --submit-candidate, or --merge-candidates."
    ;;
esac
